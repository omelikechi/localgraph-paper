# Ignore Python cache and build files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore system files
.DS_Store
Thumbs.db

# Ignore IDE/editor config files
.vscode/
.idea/

# Virtual environments
venv/
env/
*.venv/

# Logs
*.log

#--------------------------------
# Ignore large result / output files
#--------------------------------
*.graphml
*.csv
*.xlsx
*.mtx
*.gmt
*.shp
*.shx
*.dbf
*.tsv
*.txt

# Ignore all pickle files
*.pkl

#--------------------------------
# Ignore heavy data directories
#--------------------------------
applications/*/data/raw_data/
applications/*/data/gene_sets/
applications/*/data/stringdb/
applications/breast_cancer/mofa.py

#--------------------------------
# Allow simulation results
#--------------------------------
!simulations/results/
!simulations/results/*.pkl

#--------------------------------
# Hide old/extra sim results
#--------------------------------
simulations/results/old/
simulations/results/extra/

#--------------------------------
# Keep cleaned_data generally
#--------------------------------
!applications/*/data/cleaned_data/
!applications/*/data/cleaned_data/cleaned_data.pkl
!applications/*/data/cleaned_data/cleaned_data.csv

#--------------------------------
# Allow application results
#--------------------------------
!applications/*/results/
!applications/*/results/*.pkl
!applications/*/results/*.graphml

#--------------------------------
# EXCEPT Alzheimer (too large)
#--------------------------------
applications/alzheimers/data/cleaned_data/cleaned_data.pkl




